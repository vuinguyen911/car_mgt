{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testTimeout": 30000,
  "forceExit": true,
  "globalSetup": "<rootDir>/test/helpers/global-setup.ts",
  "globalTeardown": "<rootDir>/test/helpers/global-teardown.ts"
}
